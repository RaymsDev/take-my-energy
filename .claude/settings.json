{
  "permissions": {
    "allow": ["Exec(git add *)", "Exec(git commit *)"],
    "deny": ["Exec(git push *)", "Exec(kubectl *)", "Exec(helm *)"]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit *)",
            "command": "npm run format && git add -u",
            "timeout": 60,
            "statusMessage": "Running prettier before commit..."
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "nx@nx-claude-plugins": true,
    "compound-engineering@compound-engineering-plugin": true
  },
  "extraKnownMarketplaces": {
    "nx-claude-plugins": {
      "source": {
        "source": "github",
        "repo": "nrwl/nx-ai-agents-config"
      }
    }
  }
}
