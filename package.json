{
  "name": "five-of-heart",
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "start": "npm run dev",
    "dev": "nx run-many --target=serve --projects=fiveOfHeart,api",
    "dev:front": "nx serve fiveOfHeart",
    "dev:api": "nx serve api",
    "build": "nx run-many --target=build --projects=fiveOfHeart,api",
    "build:front": "nx build fiveOfHeart",
    "build:api": "nx build api",
    "format": "prettier --write .",
    "watch": "nx build --watch --configuration development",
    "test": "nx run-many --target=test",
    "test:front": "nx test fiveOfHeart",
    "test:api": "nx test api",
    "test:dto": "nx test shared-dto",
    "test:http": "httpyac run requests/*.http --env dev --all",
    "serve:ssr:fiveOfHeart": "node dist/five-of-heart/server/server.mjs",
    "lint:prettier": "prettier --check .",
    "lint:ts": "tsc -p apps/api/tsconfig.app.json --noEmit && tsc -p apps/fiveOfHeart/tsconfig.app.json --noEmit",
    "prepare": "husky"
  },
  "private": false,
  "engines": {
    "node": ">=24",
    "npm": ">=10.9.3"
  },
  "dependencies": {
    "@angular/animations": "21.2.9",
    "@angular/common": "21.2.9",
    "@angular/compiler": "21.2.9",
    "@angular/core": "21.2.9",
    "@angular/forms": "21.2.9",
    "@angular/platform-browser": "21.2.9",
    "@angular/platform-browser-dynamic": "21.2.9",
    "@angular/platform-server": "21.2.9",
    "@angular/router": "21.2.9",
    "@angular/ssr": "21.2.9",
    "@hakimio/ngx-google-analytics": "^15.0.0",
    "@nestjs/common": "^11.1.24",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.24",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.24",
    "express": "^5.2.1",
    "mongoose": "^9.6.3",
    "nestjs-zod": "^5.4.0",
    "ng-recaptcha-2": "^21.0.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.12.4",
    "rxjs": "~7.8.0",
    "schema-dts": "^2.0.0",
    "tslib": "^2.3.0",
    "zod": "^4.4.3",
    "zone.js": "~0.16.0"
  },
  "overrides": {
    "@typescript-eslint/project-service": "8.60.0",
    "@typescript-eslint/tsconfig-utils": "8.60.0",
    "@typescript-eslint/type-utils": "8.60.0",
    "@typescript-eslint/typescript-estree": "8.60.0",
    "@typescript-eslint/utils": "8.60.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "21.2.9",
    "@angular-devkit/core": "21.2.9",
    "@angular-devkit/schematics": "21.2.9",
    "@angular/cli": "21.2.9",
    "@angular/compiler-cli": "21.2.9",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^9.8.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/angular": "22.7.4",
    "@nx/eslint": "22.7.4",
    "@nx/eslint-plugin": "22.7.4",
    "@nx/jest": "22.7.4",
    "@nx/js": "^22.7.4",
    "@nx/nest": "^22.7.4",
    "@nx/node": "22.7.4",
    "@nx/web": "22.7.4",
    "@nx/webpack": "22.7.4",
    "@nx/workspace": "22.7.4",
    "@schematics/angular": "21.2.9",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@types/express": "^5.0.6",
    "@types/jasmine": "~6.0.0",
    "@types/jest": "~30.0.0",
    "@types/node": "^24.0.0",
    "@types/passport-google-oauth20": "^2.0.17",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "husky": "^9.1.6",
    "jasmine-core": "~6.2.0",
    "jest": "~30.3.0",
    "jest-environment-node": "~30.3.0",
    "jest-util": "~30.3.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
