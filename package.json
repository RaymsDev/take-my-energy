    "karma-jasmine-html-reporter": "~2.2.0",
    "nx": "22.7.4",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.0",
    "ts-node": "10.9.1",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.40.0",
    "httpyac": "^6.16.0",
    "webpack-cli": "^5.1.4"
  }
