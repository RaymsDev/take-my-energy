/*
# Gift Cards — error paths

These requests are expected to fail — assertions verify correct error codes.

*/
###
# 401 — missing Authorization header
POST {{BASE_URL}}/api/gift-cards
Content-Type: application/json

{
  "recipientName": "Alice",
  "recipientEmail": "alice@example.com",
  "senderName": "Bob",
  "serviceId": "1"
}

?? body statusCode == 401
###
# 401 — malformed token (not a valid JWT)
GET {{BASE_URL}}/api/gift-cards
Authorization: Bearer not-a-real-token

?? status 401
###
# 400/422 — missing required field (recipientEmail)
POST {{BASE_URL}}/api/gift-cards
Authorization: Bearer {{ACCESS_TOKEN}}
Content-Type: application/json

{
  "recipientName": "Alice",
  "senderName": "Bob",
  "serviceId": "1"
}

?? body statusCode == 400
###
# 404 — serviceId does not exist in catalog
POST {{BASE_URL}}/api/gift-cards
Authorization: Bearer {{ACCESS_TOKEN}}
Content-Type: application/json

{
  "recipientName": "Alice",
  "recipientEmail": "alice@example.com",
  "senderName": "Bob",
  "serviceId": "nonexistent"
}

?? body statusCode == 404
###
# 404 — invalid ObjectId format (not a 24-hex string)
GET {{BASE_URL}}/api/gift-cards/not-a-valid-id
Authorization: Bearer {{ACCESS_TOKEN}}

?? status 404
###
# 404 — valid ObjectId format but card does not exist
GET {{BASE_URL}}/api/gift-cards/507f1f77bcf86cd799439000
Authorization: Bearer {{ACCESS_TOKEN}}

?? status 404
###
# 400/422 — recipientEmail is not a valid email address
POST {{BASE_URL}}/api/gift-cards
Authorization: Bearer {{ACCESS_TOKEN}}
Content-Type: application/json

{
  "recipientName": "Alice",
  "recipientEmail": "not-an-email",
  "senderName": "Bob",
  "serviceId": "1"
}

?? body statusCode == 400
