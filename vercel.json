{
  "git": {
    "deploymentEnabled": false
  },
  "framework": "angular",
  "buildCommand": "npm run build:front",
  "outputDirectory": "dist/five-of-heart/browser",
  "installCommand": "npm install",
  "devCommand": "npm run dev:front",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://take-my-energy.onrender.com/api/:path*"
    },
    { "source": "/((?!assets|.*\\..*).*)", "destination": "/index.html" }
  ]
}
